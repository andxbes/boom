# Скопируйте в .env и вставьте токен с https://expo.dev/settings/access-tokens
# Файл .env не попадает в git.
EXPO_TOKEN=

# Первая сборка (один раз):
# 1. npm install
# 2. npm run eas:init
# 3. npm run eas:credentials:android
#    → Keystore → preview → "Generate new keystore" / доверить Expo
# 4. npm run build:apk
# 5. npm run download:apk
#
# Повторные сборки (keystore уже есть на Expo):
# npm run build:apk:ci
# npm run download:apk
